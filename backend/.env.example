# Configuración de zAI GLM
# Obtén tu API key gratis en: https://open.bigmodel.cn/
ZAI_API_KEY=your-zai-api-key-here

# Opcional: Modelo a usar (por defecto: glm-4-flash)
# Modelos disponibles:
# - glm-4-flash (Gratis, rápido, ideal para chat)
# - glm-4-plus (De pago, más potente)
# - glm-4-vision (De pago, con visión)
ZAI_MODEL=glm-4-flash
