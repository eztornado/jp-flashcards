# Configuración de Ollama - Ejemplo para copiar
# Instrucciones:
# 1. Copia este archivo a .env
# 2. Edita las líneas según tu configuración

# ==================== OLLAMA (Local - GRATIS) ====================
# Descomenta estas líneas para usar Ollama local

# URL del servidor Ollama (tu servidor remoto o local)
OLLAMA_HOST=http://cos-alicante.netbird.vpn

# Modelo a usar (elige uno)
OLLAMA_MODEL=llama3.1

# Opciones alternativas de modelos:
# OLLAMA_MODEL=gemma2:9b        # Más rápido
# OLLAMA_MODEL=mistral:nemo:latest  # Creativo
# OLLAMA_MODEL=phi3              # Pequeño y rápido

# ==================== ZAI (API Externa - RETROCOMPATIBILIDAD) ====================
# Descomenta estas líneas para usar zAI junto con Ollama
# o en vez de Ollama

ZAI_API_KEY=tu-clave-de-zai-aqui           # Obtén tu clave en https://open.bigmodel.cn/
ZAI_MODEL=glm-4-flash                       # Modelo gratuito
# Alternativas: glm-4-plus, glm-4-vision

# ==================== CONFIGURACIÓN DEL SERVIDOR ====================
PORT=3000
HOST=rpi4.netbird.vpn

# ==================== NOTAS ====================
# - Ollama debe estar corriendo en: http://cos-alicante.netbird.vpn:11434
# - Para instalar modelos: ollama pull llama3.1
# - Para iniciar Ollama: ollama serve
# - Puedes usar ambos sistemas: Ollama como principal, zAI como backup
